	partition Calendario = calculated
		mode: import
		source = ```
				
				ADDCOLUMNS(
				    CALENDAR(MIN('5-Contrato'[VIGÊNCIA INICIAL]), MAX('8-Termo Aditivo'[VIGÊNCIA FINAL])),
				    "Ano", YEAR([Date]),
				    "Mes", MONTH([Date]),
				    "Nome_Mes", FORMAT([Date], "MMM"),
				    "AnoMes", FORMAT([Date], "YYYY-MM")
				)
				
				```

	annotation PBI_Id = fe92dc93a4334443a3d9af788a8cc5dd

